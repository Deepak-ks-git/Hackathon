# =============================================================================
# GenAI Lab / LLM Configuration
# =============================================================================
# OpenAI-compatible GenAI Lab base URL. Use the root URL, not a Hugging Face URL.
GENAI_BASE_URL=https://genailab.tcs.in

# API key issued during the hackathon. Leave blank to run UI LLM calls in mock mode.
GENAI_API_KEY=sk-Zu-u-tb0bSC9YDwbj965TQ

# These defaults must be models returned by GET ${GENAI_BASE_URL}/models.
DEFAULT_MODEL=genailab-maas-DeepSeek-V3-0324
FALLBACK_MODEL=azure/genailab-maas-gpt-4o-mini

# Set true for internal labs/self-signed corporate certs.
DISABLE_SSL_VERIFY=true

# =============================================================================
# GenAI Lab /models Configuration
# =============================================================================
# Optional override. If blank, the app calls ${GENAI_BASE_URL}/models.
GENAI_MODELS_URL=

# =============================================================================
# Embedding Configuration
# =============================================================================
# Must be an embedding model returned by GET ${GENAI_BASE_URL}/models.
# Example from GenAI Lab /models:
# azure/genailab-maas-text-embedding-3-large
EMBEDDING_MODEL=azure/genailab-maas-text-embedding-3-large

# text-embedding-3-large commonly returns 3072 dimensions. The FAISS index
# uses the actual returned vector dimension dynamically during training.
EMBEDDING_DIMENSIONS=3072

# =============================================================================
# Application Behavior
# =============================================================================
CONFIDENCE_THRESHOLD=0.7
REQUEST_TIMEOUT_SECONDS=60
